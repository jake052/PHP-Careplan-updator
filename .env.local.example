# ---------------------------------------------------------------------------
# Choose your provider. Default is "azure". Switch to "openai" ONLY for local
# testing on the fictional Sam dataset. Never run a demo for a real RM (Ellie,
# Sarah, anyone) without flipping back to azure.
# ---------------------------------------------------------------------------
LLM_PROVIDER="azure"

# ---------------------------------------------------------------------------
# LOCAL TESTING ONLY — standard OpenAI API
# Use when LLM_PROVIDER="openai".
# ---------------------------------------------------------------------------
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# ---------------------------------------------------------------------------
# PRODUCTION / DEMO — Azure OpenAI, UK South region (UK-residency required)
# Use when LLM_PROVIDER="azure". This is the default and the only path you
# should ever use when showing the demo to a real provider.
# ---------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT="https://YOUR-RESOURCE.openai.azure.com"
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4o"
AZURE_OPENAI_API_VERSION="2024-10-21"
